# Default: normalize text and use LF in repository
* text=auto eol=lf

# Windows scripts keep CRLF
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# Binary assets
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.mp4 binary
*.mkv binary
*.avi binary
*.mov binary
*.flv binary
*.wmv binary
*.pt binary
*.pyc binary
